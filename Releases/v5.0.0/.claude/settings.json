  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | sed -n 's/.*\"current_dir\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' | head -1); dir=$(basename \"${cwd:-?}\"); model=$(echo \"$input\" | sed -n 's/.*\"display_name\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' | head -1); rem=$(echo \"$input\" | sed -n 's/.*\"remaining_percentage\"[[:space:]]*:[[:space:]]*\\([0-9][0-9]*\\(\\.[0-9]*\\)\\?\\).*/\\1/p' | head -1); rem_fmt=$([ -n \"$rem\" ] && printf '%.0f%%' \"$rem\" || echo '?'); echo \"${dir} | ${model:-?} | ctx ${rem_fmt}\""
  },
  "extraKnownMarketplaces": {
    "tricentis-ai-extensions": {
      "source": {
        "source": "github",
        "repo": "Tricentis-Engineering/ai-extensions"
      }
    }
  },
