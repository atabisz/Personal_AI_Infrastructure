          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-read-injection-scanner.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/gsd-phase-boundary.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "\"$HOME/.bun/bin/bun.exe\" \"$HOME/.claude/hooks/ISASync.hook.ts\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"$HOME/.bun/bin/bun.exe\" \"$HOME/.claude/hooks/CheckpointPerISC.hook.ts\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.bun/bin/bun.exe\" \"$HOME/.claude/hooks/AgentInvocation.hook.ts\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.bun/bin/bun.exe\" \"$HOME/.claude/hooks/QuestionAnswered.hook.ts\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.bun/bin/bun.exe\" \"$HOME/.claude/hooks/ContentScanner.hook.ts\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.bun/bin/bun.exe\" \"$HOME/.claude/hooks/ContentScanner.hook.ts\"",
            "timeout": 5
